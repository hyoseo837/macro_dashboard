# Domain
DOMAIN=macro.hyoseo.dev
  
# Postgres
POSTGRES_USER=macro
POSTGRES_PASSWORD=your_strong_db_password
POSTGRES_DB=macro_dashboard
  
# JWT - generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_random_secret_key
  
# AI - Google Gemini API Key
GEMINI_API_KEY=your_google_ai_api_key_here
  
# SMTP for password reset emails (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hyoseo.dev