# Domain
DOMAIN=macro.hyoseo.dev

# Postgres
POSTGRES_USER=macro
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=macro_dashboard

# JWT — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_random_secret

# SMTP for password reset emails (optional — logs to console if not set)
# Resend (free tier: 100 emails/day): smtp.resend.com, port 465
# Gmail app password: smtp.gmail.com, port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hyoseo.dev
