{$DOMAIN:localhost} {
	@api {
		path /auth/*
		path /admin/*
		path /prices
		path /prices/*
		path /widgets
		path /widgets/*
		path /timezones
		path /timezones/*
		path /news/*
		path /health
	}

	@assets-api {
		path /assets
		path /assets/search
		path /assets/currency
	}

	handle @api {
		reverse_proxy backend:8000
	}

	handle @assets-api {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
