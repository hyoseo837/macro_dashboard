{$DOMAIN:localhost} {
	handle /auth/* {
		reverse_proxy backend:8000
	}

	handle /admin/* {
		reverse_proxy backend:8000
	}

	handle /assets* {
		reverse_proxy backend:8000
	}

	handle /prices* {
		reverse_proxy backend:8000
	}

	handle /widgets* {
		reverse_proxy backend:8000
	}

	handle /timezones* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
